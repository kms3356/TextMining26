   "source": [
    "from konlpy.tag import Okt\n",
    "\n",
    "okt = Okt()\n",
    "\n",
    "text = \"판다스는 파이썬계의 엑셀입니다\"\n",
    "print(\"형태소 분석:\", okt.morphs(text))\n",
    "print(\"명사 추출:\", okt.nouns(text))\n",
    "print(\"품사 태깅:\", okt.pos(text))"
   ]
  }
